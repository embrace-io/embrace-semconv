# Shared external version pins, consumed by scripts/ (via common.sh) and CI.
# The registry's own release version is NOT pinned here.
# It is defined as part of the schema_url in model/manifest.yaml.

WEAVER_VERSION=v0.24.2

# The core OpenTelemetry semantic conventions registry this one extends. Must
# match the upstream tag in model/manifest.yaml's registry_path (verified by
# scripts/check.sh).
CORE_SEMCONV_VERSION=v1.43.0

POLICY_REPO_URL=https://github.com/open-telemetry/opentelemetry-weaver-packages.git
POLICY_REPO_REF=d84341cf20a1fef1a833ef44d318c41a770e6e64
